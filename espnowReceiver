#include <WiFi.h>
#include <esp_now.h>

const int ledPin = 8;

typedef struct struct_message {
  bool buttonPressed;
} struct_message;

volatile bool newDataAvailable = false;
struct_message myData;

void OnDataRecv(const esp_now_recv_info *info, const uint8_t *incomingData, int len) {
  if (len == sizeof(myData)) {
    memcpy((void*)&myData, incomingData, sizeof(myData));
    newDataAvailable = true;
  }
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println("Empfaenger startet");

  pinMode(ledPin, OUTPUT);
  digitalWrite(ledPin, LOW);

  WiFi.mode(WIFI_STA);

  if (esp_now_init() != ESP_OK) {
    Serial.println("ESP-NOW Fehler");
    return;
  }

  if (esp_now_register_recv_cb(OnDataRecv) != ESP_OK) {
    Serial.println("Fehler beim Registrieren des Receive-Callbacks");
    return;
  }

  Serial.println("Warte auf Daten...");
}

void loop() {
  if (newDataAvailable) {
    noInterrupts();
    bool currentButtonState = myData.buttonPressed;
    newDataAvailable = false;
    interrupts();

    Serial.print("Knopf: ");
    Serial.println(currentButtonState ? "GEDRUECKT" : "LOS");

    //  LED direkt setzen
    digitalWrite(ledPin, currentButtonState ? HIGH : LOW);
  }
}